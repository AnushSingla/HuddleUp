# HuddleUp Server Environment Variables
# Copy this file to .env and fill in your values

# ================================
# REQUIRED VARIABLES
# ================================

# MongoDB connection string
# Local: mongodb://localhost:27017/huddleup
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/huddleup
MONGO_URL=

# JWT secret for token signing (MUST be at least 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER use the default value in production!
JWT_SECRET=

# JWT token expiration times (optional - defaults shown)
# Access token: short-lived for API requests (default: 15m)
# Refresh token: long-lived for token renewal (default: 7d)
# ACCESS_TOKEN_EXPIRY=15m
# REFRESH_TOKEN_EXPIRY=7d

# ================================
# OPTIONAL VARIABLES (with defaults)
# ================================

# Node.js environment (development, production, test)
NODE_ENV=development

# Server port
PORT=5000

# Frontend URL for CORS and password reset links
CLIENT_URL=http://localhost:5173

# CORS allowed origins (comma-separated)
CORS_ORIGIN=https://huddle-up-beta.vercel.app,http://localhost:5173,http://localhost:5174

# ================================
# REDIS (Optional - for caching)
# ================================

REDIS_URL=redis://127.0.0.1:6379

# ================================
# CLOUDINARY (Optional - for file uploads)
# ================================

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ================================
# EMAIL SERVICE (Gmail SMTP)
# ================================
# Gmail SMTP Configuration
# To use Gmail:
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Use the generated 16-character password as SMTP_PASS

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_PASS=your_app_password
SMTP_FROM=noreply@huddleup.com

# ================================
# LOGGING CONFIGURATION
# ================================

# Log level: ERROR, WARN, INFO, DEBUG (default: INFO in production, DEBUG in development)
LOG_LEVEL=DEBUG

# Enable file logging (default: false in development, true in production)
LOG_TO_FILE=false

# ================================
# MONITORING (Optional - for performance)
# ================================

ENABLE_QUERY_MONITORING=true
ENABLE_QUERY_METRICS=true
